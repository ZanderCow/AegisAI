# -----------------------------------------------------------------------------
# REQUIRED ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Copy this file to `.env` in the backend directory when running the backend
# directly on your host.

# Database connection string using PostgreSQL with asyncpg
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/auth_db"

# JWT Secret Key - MUST BE AT LEAST 32 BYTES (256 bits) FOR HS256!
SECRET_KEY="replace_this_with_a_long_secure_randomly_generated_string"

# JWT Token Signing Algorithm
ALGORITHM="HS256"

# Token Expiration Lifespan
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Environment Profile (development | production | test)
ENVIRONMENT="development"

# AI Provider API Keys (leave empty if not using that provider)
GROQ_API_KEY=""
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
MOCK_PROVIDER_RESPONSES=false

# Remote Chroma server used for RAG document storage and retrieval.
CHROMA_HOST="localhost"
CHROMA_PORT=8001
CHROMA_SSL=false
CHROMA_COLLECTION_NAME="rag_documents"

# -----------------------------------------------------------------------------
# DUO MFA (optional)
# -----------------------------------------------------------------------------
MFA_ENABLED=false
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=
DUO_REDIRECT_URI=http://localhost:5173/auth/duo/callback
