# -----------------------------------------------------------------------------
# REQUIRED ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Copy this file to `.env` in the root of the project to run the application.

# Database connection string using PostgreSQL with asyncpg
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/auth_db"

# JWT Secret Key - MUST BE AT LEAST 32 BYTES (256 bits) FOR HS256!
# You can generate a random secure key in your terminal using:
#   openssl rand -hex 32
SECRET_KEY="replace_this_with_a_long_secure_randomly_generated_string"

# JWT Token Signing Algorithm
ALGORITHM="HS256"

# Token Expiration Lifespan
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Environment Profile (development | production)
# "production" enables standard application logging output
ENVIRONMENT="development"

# AI Provider API Keys (leave empty if not using that provider)
GROQ_API_KEY=""
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""

# Remote Chroma server used for RAG document storage and retrieval.
# If you run Chroma in Docker on your host, publish it on a free port such as
# 8001 and point the backend there. Docker Compose overrides these to use the
# internal `chroma` service name.
CHROMA_HOST="localhost"
CHROMA_PORT=8001
CHROMA_SSL=false
CHROMA_COLLECTION_NAME="rag_documents"

# Legacy note: the backend no longer uses CHROMA_PATH as its primary runtime
# storage mode. Configure a remote Chroma endpoint with the variables above.

# -----------------------------------------------------------------------------
# DUO MFA (optional)
# -----------------------------------------------------------------------------
# Set MFA_ENABLED=true to require Duo MFA on every login.
# When enabled, all four Duo variables below are required or the app will
# refuse to start.
#
# Create a Web SDK application in the Duo Admin Panel to obtain these values:
#   https://admin.duosecurity.com -> Applications -> Protect an Application -> Web SDK
#
# IMPORTANT: DUO_REDIRECT_URI must match the URI registered in the Duo Admin
# Panel exactly. For production, replace localhost with your real domain.
MFA_ENABLED=false
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=
# Development default - change to your production domain before deploying:
DUO_REDIRECT_URI=http://localhost:5173/auth/duo/callback
